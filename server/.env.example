# Sentori server (Phase 2 dev configuration)
#
# Bearer token used by SDKs to ingest events.
# Production resolves tokens from the database (Phase 5+).

SENTORI_DEV_TOKEN=st_pk_dev0000000000000000000000

# Postgres connection (optional). When set, events are dual-written to DB.
# Boot the local container first: bash scripts/dev-up.sh
# (host ports 55434/56381 chosen to coexist with other goliajp dev DBs)
# DATABASE_URL=postgres://postgres:dev@127.0.0.1:55434/sentori
# VALKEY_URL=redis://127.0.0.1:56381

# Logging:
# Default: "info,sentori_server=debug,tower_http=info"
# Override e.g.:
# RUST_LOG=trace
