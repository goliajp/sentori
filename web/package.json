{
  "name": "@sentori/web",
  "private": true,
  "version": "1.0.0-rc.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && prettier --write src/ && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit && eslint src/ && prettier --check src/",
    "fix": "eslint --fix src/ && prettier --write src/",
    "lhci": "bunx @lhci/cli@^0.16 autorun --config=./lighthouserc.cjs",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@goliapkg/sentori-react": "workspace:*",
    "@tanstack/react-query": "^5.100.10",
    "@wooorm/starry-night": "^3.9.0",
    "axios": "^1.16.1",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "jotai": "^2.20.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hotkeys-hook": "^5",
    "react-router": "^7.15.1",
    "tailwindcss": "4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
