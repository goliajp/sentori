{
  "name": "@sentori/web",
  "private": true,
  "version": "1.6.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && prettier --write src/ && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit && eslint src/ && prettier --check src/",
    "fix": "eslint --fix src/ && prettier --write src/",
    "lhci": "bunx @lhci/cli@^0.16 autorun --config=./lighthouserc.cjs",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@goliapkg/gds": "^2.2.0",
    "@goliapkg/sentori-react": "workspace:*",
    "@tanstack/query-sync-storage-persister": "^5.101.3",
    "@tanstack/react-query": "^5.101.3",
    "@tanstack/react-query-persist-client": "^5.101.3",
    "@wooorm/starry-night": "^3.10.0",
    "axios": "^1.18.1",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "jotai": "^2.20.2",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hotkeys-hook": "^5",
    "react-router": "^8.2.0",
    "tailwindcss": "4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
