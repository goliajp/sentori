# Sentori SaaS control plane — copy to .env + edit.

POSTGRES_USER=sentori_saas
POSTGRES_PASSWORD=CHANGE_ME_NOW
POSTGRES_DB=sentori_saas
POSTGRES_PORT=5433

SENTORI_SAAS_PORT=9090
SENTORI_SAAS_VERSION=0.1.0
RUST_LOG=info,sqlx=warn

# Set to enable Stripe webhook endpoint. Get from
# https://dashboard.stripe.com/webhooks → reveal signing
# secret (`whsec_xxx`).
SENTORI_STRIPE_WEBHOOK_SECRET=
