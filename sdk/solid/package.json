{
  "name": "@goliapkg/sentori-solid",
  "version": "0.1.3",
  "description": "SolidJS adapter for Sentori — ErrorBoundary helper, solid-router navigation tracing.",
  "license": "MIT",
  "homepage": "https://sentori.golia.jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goliajp/sentori.git",
    "directory": "sdk/solid"
  },
  "bugs": {
    "url": "https://github.com/goliajp/sentori/issues"
  },
  "keywords": [
    "sentori",
    "solid",
    "solidjs",
    "error-tracking"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "peerDependencies": {
    "solid-js": ">=1.8"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    }
  },
  "dependencies": {
    "@goliapkg/sentori-core": "0.8.3",
    "@goliapkg/sentori-javascript": "0.4.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6"
  },
  "publishConfig": {
    "access": "public"
  }
}
