{
  "name": "@goliapkg/sentori-expo",
  "version": "3.0.0",
  "description": "Expo adapter for Sentori — Config Plugin marker, expo-application auto-config, EAS post-build helper. Built on @goliapkg/sentori-react-native.",
  "license": "Apache-2.0 OR MIT",
  "author": "GOLIA K.K. <takagi@golia.jp> (https://golia.jp)",
  "homepage": "https://sentori.golia.jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goliajp/sentori.git",
    "directory": "sdk/expo"
  },
  "bugs": {
    "url": "https://github.com/goliajp/sentori/issues"
  },
  "keywords": [
    "sentori",
    "error-tracking",
    "expo",
    "react-native",
    "config-plugin"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./eas-post-build": "./scripts/eas-post-build.mjs"
  },
  "files": [
    "lib/",
    "src/",
    "app.plugin.js",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "peerDependencies": {
    "@goliapkg/sentori-react-native": ">=2.0.0",
    "expo": ">=50",
    "expo-application": ">=5",
    "react-native": ">=0.74"
  },
  "peerDependenciesMeta": {
    "expo-application": {
      "optional": true
    }
  },
  "dependencies": {
    "@expo/config-plugins": "^9 || ^10"
  },
  "devDependencies": {
    "@goliapkg/sentori-react-native": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^6"
  },
  "publishConfig": {
    "access": "public"
  }
}
