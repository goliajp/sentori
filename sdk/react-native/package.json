{
  "name": "@goliapkg/sentori-react-native",
  "version": "0.9.6",
  "description": "Sentori SDK for React Native \u2014 JS-layer error capture, native crash handlers (iOS / Android), batched transport, fetch + react-navigation tracing.",
  "license": "MIT",
  "homepage": "https://sentori.golia.jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goliajp/sentori.git",
    "directory": "sdk/react-native"
  },
  "bugs": {
    "url": "https://github.com/goliajp/sentori/issues"
  },
  "keywords": [
    "react-native",
    "expo",
    "error-tracking",
    "crash-reporting",
    "monitoring",
    "sentori"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/",
    "src/",
    "android/src/",
    "android/build.gradle",
    "ios/",
    "expo-module.config.json",
    "SentoriReactNative.podspec",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "peerDependencies": {
    "expo-modules-core": ">=2.0",
    "react": ">=18",
    "react-native": ">=0.74"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "@react-native-community/netinfo": {
      "optional": true
    },
    "expo-modules-core": {
      "optional": true
    },
    "expo-sensors": {
      "optional": true
    },
    "expo-updates": {
      "optional": true
    },
    "react-native-code-push": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "typescript": "^6"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@goliapkg/sentori-core": "0.8.3"
  }
}
