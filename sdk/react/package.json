{
  "name": "@goliapkg/sentori-react",
  "version": "0.3.0",
  "description": "React adapter for Sentori — Provider, ErrorBoundary (resetKeys + render-prop), Suspense, react-router breadcrumbs, and hooks built on @goliapkg/sentori-javascript.",
  "license": "MIT",
  "homepage": "https://sentori.golia.jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goliajp/sentori.git",
    "directory": "sdk/react"
  },
  "bugs": {
    "url": "https://github.com/goliajp/sentori/issues"
  },
  "keywords": [
    "sentori",
    "error-tracking",
    "react",
    "error-boundary"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./router": {
      "types": "./lib/router.d.ts",
      "default": "./lib/router.js"
    }
  },
  "files": [
    "lib/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-router": ">=7"
  },
  "peerDependenciesMeta": {
    "react-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@goliapkg/sentori-core": "0.2.0",
    "@goliapkg/sentori-javascript": "0.2.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^17",
    "@testing-library/react": "^16",
    "@types/bun": "latest",
    "@types/react": "^19",
    "react": "^19",
    "react-dom": "^19",
    "react-router": "^7",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}
